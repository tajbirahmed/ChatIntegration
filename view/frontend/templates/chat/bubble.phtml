<?php

/**
 * BS23 Chat Integration – Floating Chat Bubble Template
 *
 * @var \Magento\Framework\View\Element\Template $block
 * @var \BS23\ChatIntegration\ViewModel\ChatConfig $viewModel
 */
declare(strict_types=1);

/** @var \BS23\ChatIntegration\ViewModel\ChatConfig $viewModel */
$viewModel = $block->getData('view_model');

// Bail early if disabled or no entries configured
if (!$viewModel->isEnabled()) {
    return;
}

$entries = $viewModel->getChatEntries();
if (empty($entries)) {
    return;
}

$position      = $viewModel->getPosition();       // lower_right | lower_left | upper_right
$layoutStyle   = $viewModel->getLayoutStyle();     // vertical | horizontal | circular
$bubbleSize    = $viewModel->getBubbleSize();      // int px
$iconSize      = $viewModel->getIconSize();        // int px
$iconSpacing   = $viewModel->getIconSpacing();     // int px
$bubbleBg      = $viewModel->getBubbleBgColor();   // validated hex
$hoverEnabled  = $viewModel->isHoverEffectEnabled();

$isSingle      = count($entries) === 1;
$singleEntry   = $isSingle ? reset($entries) : null;
$entryCount    = count($entries);

// Admin-uploaded icons for the multi-entry bubble button (empty string = use default SVG)
$bubbleIconUrl = $viewModel->getBubbleIconUrl();
$closeIconUrl  = $viewModel->getCloseIconUrl();

// Build inline CSS custom-property string for runtime values from admin config
$inlineStyle = sprintf(
    '--bs23-bubble-size:%dpx;--bs23-icon-size:%dpx;--bs23-icon-spacing:%dpx;',
    $bubbleSize,
    $iconSize,
    $iconSpacing
);
if ($bubbleBg !== '') {
    $inlineStyle .= '--bs23-bubble-bg:' . $bubbleBg . ';';
}

// CSS class list for the wrapper — convert underscore config values to hyphen CSS classes
$wrapperClasses = implode(' ', array_filter([
    'bs23-chat-wrapper',
    'bs23-pos-' . str_replace('_', '-', $position),
    'bs23-layout-' . str_replace('_', '-', $layoutStyle),
    $hoverEnabled ? 'bs23-hover-on' : '',
    $bubbleBg === '' ? 'bs23-no-bg' : '',
]));
?>
<div class="<?= $viewModel->escapeHtmlAttr($wrapperClasses) ?>"
     id="bs23ChatWrapper"
     style="<?= /* @noEscape CSS custom properties – values are validated server-side */ $inlineStyle ?>"
     data-layout="<?= $viewModel->escapeHtmlAttr($layoutStyle) ?>"
     data-count="<?= (int) $entryCount ?>"
     role="complementary"
     aria-label="<?= $viewModel->escapeHtmlAttr((string) __('Chat with us')) ?>">

    <?php if (!$isSingle): ?>
    <?php /* ── Multi-entry: collapsible panel ──────────────────────────── */ ?>
    <div class="bs23-chat-options"
         id="bs23ChatOptions"
         role="list"
         aria-label="<?= $viewModel->escapeHtmlAttr((string) __('Chat options')) ?>"
         aria-hidden="true">

        <?php foreach ($entries as $entry): ?>
        <?php $entryBgStyle = ($entry->getIconBgEnabled() && $entry->getIconBgColor())
            ? ' style="background-color:' . $viewModel->escapeHtmlAttr((string) $entry->getIconBgColor()) . '"'
            : ''; ?>
        <div class="bs23-chat-option" role="listitem">
            <a href="<?= $viewModel->escapeUrl($entry->getUrl()) ?>"
               target="_blank"
               rel="noopener noreferrer"
               class="bs23-chat-link"
               aria-label="<?= $viewModel->escapeHtmlAttr($entry->getName()) ?>"
               tabindex="-1"<?= /* @noEscape validated hex color */ $entryBgStyle ?>>

                <?php if ($entry->getIcon()): ?>
                <img src="<?= $viewModel->escapeUrl($viewModel->getIconUrl((string) $entry->getIcon())) ?>"
                     alt="<?= $viewModel->escapeHtmlAttr($entry->getName()) ?>"
                     width="<?= (int) $iconSize ?>"
                     height="<?= (int) $iconSize ?>"
                     loading="lazy"/>
                <?php else: ?>
                <?php /* Fallback SVG chat icon when no image is uploaded */ ?>
                <span class="bs23-icon-fallback" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"
                         width="<?= (int) $iconSize ?>" height="<?= (int) $iconSize ?>">
                        <path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2z"/>
                    </svg>
                </span>
                <?php endif; ?>

                <span class="bs23-chat-tooltip" role="tooltip">
                    <?= $viewModel->escapeHtml($entry->getName()) ?>
                </span>
            </a>
        </div>
        <?php endforeach; ?>
    </div>
    <?php endif; ?>

    <?php /* ── Main bubble button ──────────────────────────────────────── */ ?>
    <?php if ($isSingle && $singleEntry): ?>
    <?php /* Single entry: bubble IS the direct link – no toggle needed */ ?>
    <a href="<?= $viewModel->escapeUrl($singleEntry->getUrl()) ?>"
       target="_blank"
       rel="noopener noreferrer"
       class="bs23-bubble-btn"
       aria-label="<?= $viewModel->escapeHtmlAttr((string) __('Chat on %1', $singleEntry->getName())) ?>">

        <?php if ($singleEntry->getIcon()): ?>
        <img src="<?= $viewModel->escapeUrl($viewModel->getIconUrl((string) $singleEntry->getIcon())) ?>"
             alt="<?= $viewModel->escapeHtmlAttr($singleEntry->getName()) ?>"
             width="<?= (int) $iconSize ?>"
             height="<?= (int) $iconSize ?>"/>
        <?php else: ?>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white"
             aria-hidden="true" focusable="false">
            <path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2z"/>
        </svg>
        <?php endif; ?>
    </a>

    <?php else: ?>
    <?php /* Multiple entries: toggle button */ ?>
    <button class="bs23-bubble-btn"
            id="bs23BubbleBtn"
            type="button"
            aria-label="<?= $viewModel->escapeHtmlAttr((string) __('Open chat options')) ?>"
            aria-expanded="false"
            aria-controls="bs23ChatOptions">

        <?php /* Chat icon – visible when panel is closed */ ?>
        <span class="bs23-icon bs23-icon-open" aria-hidden="true">
            <?php if ($bubbleIconUrl): ?>
            <img src="<?= $viewModel->escapeUrl($bubbleIconUrl) ?>"
                 alt="" width="<?= (int) $iconSize ?>" height="<?= (int) $iconSize ?>"/>
            <?php else: ?>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white" focusable="false">
                <path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2z"/>
            </svg>
            <?php endif; ?>
        </span>

        <?php /* Close (×) icon – visible when panel is open */ ?>
        <span class="bs23-icon bs23-icon-close" aria-hidden="true">
            <?php if ($closeIconUrl): ?>
            <img src="<?= $viewModel->escapeUrl($closeIconUrl) ?>"
                 alt="" width="<?= (int) $iconSize ?>" height="<?= (int) $iconSize ?>"/>
            <?php else: ?>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white" focusable="false">
                <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
            </svg>
            <?php endif; ?>
        </span>
    </button>
    <?php endif; ?>
</div>
