<?php

/**
 * BS23 Chat Integration – Floating Chat Bubble Template
 *
 * @var \Magento\Framework\View\Element\Template $block
 * @var \BS23\ChatIntegration\ViewModel\ChatConfig $viewModel
 */
declare(strict_types=1);

/** @var \BS23\ChatIntegration\ViewModel\ChatConfig $viewModel */
$viewModel = $block->getData('view_model');

// Bail early if disabled or no entries configured
if (!$viewModel->isEnabled()) {
    return;
}

$entries = $viewModel->getChatEntries();
if (empty($entries)) {
    return;
}

$position      = $viewModel->getPosition();       // lower_right | lower_left | upper_right
$layoutStyle   = $viewModel->getLayoutStyle();     // vertical | horizontal | circular
$bubbleSize    = $viewModel->getBubbleSize();      // int px
$iconSize      = $viewModel->getIconSize();        // int px
$iconSpacing   = $viewModel->getIconSpacing();     // int px
$bubbleBg      = $viewModel->getBubbleBgColor();   // validated hex
$hoverEnabled  = $viewModel->isHoverEffectEnabled();

$isSingle      = count($entries) === 1;
$singleEntry   = $isSingle ? reset($entries) : null;
$entryCount    = count($entries);

// Build inline CSS custom-property string for runtime values from admin config
$inlineStyle = sprintf(
    '--bs23-bubble-size:%dpx;--bs23-icon-size:%dpx;--bs23-icon-spacing:%dpx;--bs23-bubble-bg:%s;',
    $bubbleSize,
    $iconSize,
    $iconSpacing,
    $bubbleBg
);

// CSS class list for the wrapper — convert underscore config values to hyphen CSS classes
$wrapperClasses = implode(' ', array_filter([
    'bs23-chat-wrapper',
    'bs23-pos-' . str_replace('_', '-', $position),
    'bs23-layout-' . str_replace('_', '-', $layoutStyle),
    $hoverEnabled ? 'bs23-hover-on' : '',
]));
?>
<div class="<?= $viewModel->escapeHtmlAttr($wrapperClasses) ?>"
     id="bs23ChatWrapper"
     style="<?= /* @noEscape CSS custom properties – values are validated server-side */ $inlineStyle ?>"
     data-layout="<?= $viewModel->escapeHtmlAttr($layoutStyle) ?>"
     data-count="<?= (int) $entryCount ?>"
     role="complementary"
     aria-label="<?= $viewModel->escapeHtmlAttr((string) __('Chat with us')) ?>">

    <?php if (!$isSingle): ?>
    <?php /* ── Multi-entry: collapsible panel ──────────────────────────── */ ?>
    <div class="bs23-chat-options"
         id="bs23ChatOptions"
         role="list"
         aria-label="<?= $viewModel->escapeHtmlAttr((string) __('Chat options')) ?>"
         aria-hidden="true">

        <?php foreach ($entries as $entry): ?>
        <div class="bs23-chat-option" role="listitem">
            <a href="<?= $viewModel->escapeUrl($entry->getUrl()) ?>"
               target="_blank"
               rel="noopener noreferrer"
               class="bs23-chat-link"
               aria-label="<?= $viewModel->escapeHtmlAttr($entry->getName()) ?>"
               tabindex="-1">

                <?php if ($entry->getIcon()): ?>
                <img src="<?= $viewModel->escapeUrl($viewModel->getIconUrl((string) $entry->getIcon())) ?>"
                     alt="<?= $viewModel->escapeHtmlAttr($entry->getName()) ?>"
                     width="<?= (int) $iconSize ?>"
                     height="<?= (int) $iconSize ?>"
                     loading="lazy"/>
                <?php else: ?>
                <?php /* Fallback SVG chat icon when no image is uploaded */ ?>
                <span class="bs23-icon-fallback" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"
                         width="<?= (int) $iconSize ?>" height="<?= (int) $iconSize ?>">
                        <path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2z"/>
                    </svg>
                </span>
                <?php endif; ?>

                <span class="bs23-chat-tooltip" role="tooltip">
                    <?= $viewModel->escapeHtml($entry->getName()) ?>
                </span>
            </a>
        </div>
        <?php endforeach; ?>
    </div>
    <?php endif; ?>

    <?php /* ── Main bubble button ──────────────────────────────────────── */ ?>
    <?php if ($isSingle && $singleEntry): ?>
    <?php /* Single entry: bubble IS the direct link – no toggle needed */ ?>
    <a href="<?= $viewModel->escapeUrl($singleEntry->getUrl()) ?>"
       target="_blank"
       rel="noopener noreferrer"
       class="bs23-bubble-btn"
       aria-label="<?= $viewModel->escapeHtmlAttr((string) __('Chat on %1', $singleEntry->getName())) ?>">

        <?php if ($singleEntry->getIcon()): ?>
        <img src="<?= $viewModel->escapeUrl($viewModel->getIconUrl((string) $singleEntry->getIcon())) ?>"
             alt="<?= $viewModel->escapeHtmlAttr($singleEntry->getName()) ?>"
             width="<?= (int) $iconSize ?>"
             height="<?= (int) $iconSize ?>"/>
        <?php else: ?>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white"
             aria-hidden="true" focusable="false">
            <path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2z"/>
        </svg>
        <?php endif; ?>
    </a>

    <?php else: ?>
    <?php /* Multiple entries: toggle button */ ?>
    <button class="bs23-bubble-btn"
            id="bs23BubbleBtn"
            type="button"
            aria-label="<?= $viewModel->escapeHtmlAttr((string) __('Open chat options')) ?>"
            aria-expanded="false"
            aria-controls="bs23ChatOptions">

        <?php /* Chat icon – visible when panel is closed */ ?>
        <span class="bs23-icon bs23-icon-open" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white" focusable="false">
                <path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2z"/>
            </svg>
        </span>

        <?php /* Close (×) icon – visible when panel is open */ ?>
        <span class="bs23-icon bs23-icon-close" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white" focusable="false">
                <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
            </svg>
        </span>
    </button>
    <?php endif; ?>
</div>

<?php if (!$isSingle): ?>
<?php /*
 * Inline script placed at end-of-body – DOM is ready, no DOMContentLoaded needed.
 * No jQuery, no RequireJS. Vanilla ES5-compatible for broadest browser support.
 * Circular layout positions items using trigonometry via CSS custom properties.
 * Total script weight (un-minified): ~1.8 kb.
 */ ?>
<script>
(function () {
    'use strict';

    var wrapper = document.getElementById('bs23ChatWrapper');
    var btn     = document.getElementById('bs23BubbleBtn');
    var panel   = document.getElementById('bs23ChatOptions');

    if (!wrapper || !btn || !panel) { return; }

    var layout = wrapper.getAttribute('data-layout') || 'vertical';
    var count  = parseInt(wrapper.getAttribute('data-count'), 10) || 0;

    /* ── Smart circular ring positioning ───────────────────────────────────
       Instead of a fixed full 360° ring, we:
       1. Measure the bubble's real pixel position on screen at runtime.
       2. Compute the direction with the most available viewport space (atan2).
       3. Fan icons in a dynamic arc centered on that inward direction so
          icons never clip outside the viewport edge.

       Arc span grows with item count (30° per item) capped at 150°, keeping
       all icons within 75° of the inward diagonal regardless of count.
    ──────────────────────────────────────────────────────────────────────── */
    function positionCircularItems() {
        if (layout !== 'circular' || count < 2) { return; }

        var items    = panel.querySelectorAll('.bs23-chat-option');
        var bubblePx = parseInt(
            getComputedStyle(wrapper).getPropertyValue('--bs23-bubble-size'), 10
        ) || 56;
        var radius   = Math.max(bubblePx * 1.6, 80);

        // Bubble centre on screen
        var rect = wrapper.getBoundingClientRect();
        var cx   = rect.left + rect.width  / 2;
        var cy   = rect.top  + rect.height / 2;
        var W    = window.innerWidth  || document.documentElement.clientWidth;
        var H    = window.innerHeight || document.documentElement.clientHeight;

        // Normalised position: 0 = left/top edge, 1 = right/bottom edge
        // wx > 0 → bubble is right of centre → prefer going left  (-wx)
        // wy > 0 → bubble is below centre    → prefer going up    (-wy)
        // In our CSS coord system positive y = DOWN, so -wy = up on screen ✓
        var wx = cx / W * 2 - 1;
        var wy = cy / H * 2 - 1;

        // Center angle points away from the corner (toward most screen space)
        var centerAngle = Math.atan2(-wy, -wx);

        // Arc span: 30° per item, capped at 150° so icons stay near center
        var span       = Math.min(count * (Math.PI / 6), Math.PI * 5 / 6);
        var startAngle = centerAngle - span / 2;

        items.forEach(function (item, i) {
            var angle = count > 1
                ? startAngle + (i / (count - 1)) * span
                : centerAngle;
            item.style.setProperty('--bs23-ring-x', Math.round(Math.cos(angle) * radius) + 'px');
            item.style.setProperty('--bs23-ring-y', Math.round(Math.sin(angle) * radius) + 'px');
        });
    }

    // Recalculate on resize (handles orientation changes on mobile)
    window.addEventListener('resize', positionCircularItems);

    /* ── Panel open/close ───────────────────────────────────────────── */
    function openPanel() {
        wrapper.classList.add('is-active');
        btn.setAttribute('aria-expanded', 'true');
        btn.setAttribute('aria-label', btn.getAttribute('aria-label')
            .replace('Open', 'Close'));
        panel.setAttribute('aria-hidden', 'false');
        // Restore tab-order for links inside the panel
        panel.querySelectorAll('.bs23-chat-link').forEach(function (link) {
            link.setAttribute('tabindex', '0');
        });
    }

    function closePanel() {
        wrapper.classList.remove('is-active');
        btn.setAttribute('aria-expanded', 'false');
        panel.setAttribute('aria-hidden', 'true');
        // Remove links from tab order when hidden
        panel.querySelectorAll('.bs23-chat-link').forEach(function (link) {
            link.setAttribute('tabindex', '-1');
        });
    }

    function togglePanel() {
        if (wrapper.classList.contains('is-active')) {
            closePanel();
        } else {
            openPanel();
        }
    }

    /* ── Event listeners ───────────────────────────────────────────── */
    btn.addEventListener('click', function (e) {
        e.stopPropagation();
        togglePanel();
    });

    // Close when user clicks outside the widget
    document.addEventListener('click', function (e) {
        if (wrapper && !wrapper.contains(e.target)) {
            closePanel();
        }
    });

    // Close on Escape key – return focus to button
    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && wrapper.classList.contains('is-active')) {
            closePanel();
            btn.focus();
        }
    });

    /* ── Initialise ─────────────────────────────────────────────────── */
    positionCircularItems();
}());
</script>
<?php endif; ?>
