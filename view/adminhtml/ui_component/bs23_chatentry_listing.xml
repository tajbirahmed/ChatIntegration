<?xml version="1.0" encoding="UTF-8"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">

    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">
                bs23_chatentry_listing.bs23_chatentry_listing_data_source
            </item>
        </item>
    </argument>

    <settings>
        <buttons>
            <button name="add">
                <url path="*/*/new"/>
                <class>primary</class>
                <label translate="true">Add New Chat Entry</label>
            </button>
        </buttons>
        <spinner>bs23_chatentry_listing_columns</spinner>
        <deps>
            <dep>bs23_chatentry_listing.bs23_chatentry_listing_data_source</dep>
        </deps>
    </settings>

    <!-- ── Data Source ─────────────────────────────────────────────────── -->
    <dataSource name="bs23_chatentry_listing_data_source"
                component="Magento_Ui/js/grid/provider">
        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">entry_id</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>BS23_ChatIntegration::chat_entry</aclResource>
        <dataProvider class="BS23\ChatIntegration\Ui\DataProvider\ChatEntry\Listing\DataProvider"
                      name="bs23_chatentry_listing_data_source">
            <settings>
                <requestFieldName>entry_id</requestFieldName>
                <primaryFieldName>entry_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>

    <!-- ── Toolbar ─────────────────────────────────────────────────────── -->
    <listingToolbar name="listing_top">
        <settings>
            <sticky>true</sticky>
        </settings>
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filterSearch name="fulltext"/>

        <filters name="listing_filters"/>

        <massaction name="listing_massaction">
            <action name="delete">
                <settings>
                    <confirm>
                        <message translate="true">Are you sure you want to delete the selected entries?</message>
                        <title translate="true">Delete Items</title>
                    </confirm>
                    <url path="bs23_chatintegration/chatentry/massDelete"/>
                    <type>delete</type>
                    <label translate="true">Delete</label>
                </settings>
            </action>
            <action name="enable">
                <settings>
                    <url path="bs23_chatintegration/chatentry/massEnable"/>
                    <type>enable</type>
                    <label translate="true">Enable</label>
                </settings>
            </action>
            <action name="disable">
                <settings>
                    <url path="bs23_chatintegration/chatentry/massDisable"/>
                    <type>disable</type>
                    <label translate="true">Disable</label>
                </settings>
            </action>
        </massaction>

        <paging name="listing_paging"/>
    </listingToolbar>

    <!-- ── Columns ─────────────────────────────────────────────────────── -->
    <columns name="bs23_chatentry_listing_columns">
        <settings>
            <editorConfig>
                <param name="selectProvider" xsi:type="string">
                    bs23_chatentry_listing.bs23_chatentry_listing.bs23_chatentry_listing_columns.ids
                </param>
                <param name="enabled" xsi:type="boolean">true</param>
                <param name="indexField" xsi:type="string">entry_id</param>
            </editorConfig>
        </settings>

        <!-- Checkbox selection column -->
        <selectionsColumn name="ids">
            <settings>
                <indexField>entry_id</indexField>
            </settings>
        </selectionsColumn>

        <!-- ID -->
        <column name="entry_id">
            <settings>
                <filter>textRange</filter>
                <label translate="true">ID</label>
                <sorting>asc</sorting>
            </settings>
        </column>

        <!-- Chat Name -->
        <column name="name">
            <settings>
                <filter>text</filter>
                <label translate="true">Chat Name</label>
            </settings>
        </column>

        <!-- Deep Link URL -->
        <column name="url">
            <settings>
                <filter>text</filter>
                <label translate="true">Deep Link URL</label>
            </settings>
        </column>

        <!-- Sort Order -->
        <column name="sort_order">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Sort Order</label>
            </settings>
        </column>

        <!-- Status -->
        <column name="is_enabled" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <options class="Magento\Config\Model\Config\Source\Yesno"/>
                <filter>select</filter>
                <dataType>select</dataType>
                <label translate="true">Status</label>
            </settings>
        </column>

        <!-- Created At -->
        <column name="created_at"
                class="Magento\Ui\Component\Listing\Columns\Date"
                component="Magento_Ui/js/grid/columns/date">
            <settings>
                <filter>dateRange</filter>
                <dataType>date</dataType>
                <label translate="true">Created At</label>
            </settings>
        </column>

        <!-- Actions (Edit / Delete) -->
        <actionsColumn name="actions"
                       class="BS23\ChatIntegration\Ui\Component\Listing\Column\ChatEntryActions">
            <settings>
                <indexField>entry_id</indexField>
                <label translate="true">Actions</label>
            </settings>
        </actionsColumn>
    </columns>
</listing>
